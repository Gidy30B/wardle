// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum CaseEditorialStatus {
  DRAFT
  VALIDATING
  VALIDATED
  REVIEW
  NEEDS_EDIT
  APPROVED
  READY_TO_PUBLISH
  PUBLISHED
  REJECTED
}

enum ValidationOutcome {
  PASSED
  FAILED
  ERROR
}

enum ReviewDecision {
  APPROVED
  REJECTED
  NEEDS_EDIT
}

enum CaseSource {
  GENERATED
  MANUAL
  ADMIN_EDIT
  RESTORED
}

enum PublishTrack {
  DAILY
  PREMIUM
  PRACTICE
}

enum OrganizationType {
  UNIVERSITY
  HOSPITAL
  COLLEGE
  OTHER
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganizationMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum DiagnosisAliasKind {
  CANONICAL
  ACCEPTED
  ABBREVIATION
  SEARCH_ONLY
}

enum DiagnosisRegistryStatus {
  ACTIVE
  HIDDEN
  DEPRECATED
  DRAFT
}

enum DiagnosisMappingStatus {
  MATCHED
  REVIEW_REQUIRED
  UNRESOLVED
  NEW_REGISTRY_ENTRY_NEEDED
}

enum DiagnosisMappingMethod {
  EXACT_ALIAS
  NORMALIZED_ALIAS
  EDITOR_SELECTED
  MANUAL_CREATED
  LEGACY_BACKFILL
  NONE
}

model Diagnosis {
  id            String               @id @default(uuid())
  name          String               @unique
  system        String?
  embeddings    DiagnosisEmbedding[]
  synonyms      Synonym[]
  cases         Case[]
  caseRevisions CaseRevision[]
  registryEntry DiagnosisRegistry?   @relation("LegacyDiagnosisRegistry")
}

model DiagnosisEmbedding {
  id          String                  @id @default(uuid())
  diagnosisId String
  vector      Unsupported("vector(1536)")
  type        String
  createdAt   DateTime                @default(now())
  diagnosis   Diagnosis               @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([diagnosisId])
  @@index([type])
}

model Synonym {
  id          String    @id @default(uuid())
  term        String    @unique
  diagnosisId String
  diagnosis   Diagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([diagnosisId])
}

model DiagnosisRegistry {
  id                    String                  @id @default(uuid())
  legacyDiagnosisId     String?                 @unique
  canonicalName         String
  canonicalNormalized   String                  @unique
  displayLabel          String
  status                DiagnosisRegistryStatus @default(ACTIVE)
  active                Boolean                 @default(true)
  isDescriptive         Boolean                 @default(false)
  isCompositional       Boolean                 @default(false)
  searchPriority        Int                     @default(0)
  icd10Code             String?
  icd11Code             String?
  category              String?
  specialty             String?
  notes                 String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  legacyDiagnosis       Diagnosis?              @relation("LegacyDiagnosisRegistry", fields: [legacyDiagnosisId], references: [id], onDelete: SetNull)
  aliases               DiagnosisAlias[]
  cases                 Case[]                  @relation("CaseDiagnosisRegistry")
  caseRevisions         CaseRevision[]          @relation("CaseRevisionDiagnosisRegistry")
  selectedAttempts      Attempt[]               @relation("AttemptSelectedDiagnosisRegistry")
  strictMatchedAttempts Attempt[]               @relation("AttemptStrictMatchedDiagnosisRegistry")

  @@index([status])
  @@index([active])
  @@index([displayLabel])
  @@index([searchPriority])
}

model DiagnosisAlias {
  id                  String             @id @default(uuid())
  diagnosisRegistryId String
  term                String
  normalizedTerm      String
  kind                DiagnosisAliasKind
  acceptedForMatch    Boolean            @default(false)
  rank                Int                @default(0)
  source              String?
  active              Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  diagnosis           DiagnosisRegistry  @relation(fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)
  selectedAttempts    Attempt[]          @relation("AttemptSelectedAlias")
  strictMatchedAttempts Attempt[]        @relation("AttemptStrictMatchedAlias")

  @@unique([diagnosisRegistryId, normalizedTerm])
  @@index([normalizedTerm, active])
  @@index([diagnosisRegistryId, active, acceptedForMatch])
}

model Case {
  id                         String                 @id @default(uuid())
  title                      String
  date                       DateTime               @unique
  difficulty                 String
  history                    String
  symptoms                   String[]
  labs                       Json?
  clues                      Json?
  explanation                Json?
  differentials              String[]               @default([])
  editorialStatus            CaseEditorialStatus?
  approvedAt                 DateTime?
  approvedByUserId           String?
  currentRevisionId          String?                @unique
  diagnosisId                String
  diagnosisRegistryId        String?
  proposedDiagnosisText      String
  diagnosisMappingStatus     DiagnosisMappingStatus
  diagnosisMappingMethod     DiagnosisMappingMethod
  diagnosisMappingConfidence Float?
  diagnosisEditorialNote     String?
  diagnosis                  Diagnosis              @relation(fields: [diagnosisId], references: [id], onDelete: Restrict)
  diagnosisRegistry          DiagnosisRegistry?     @relation("CaseDiagnosisRegistry", fields: [diagnosisRegistryId], references: [id], onDelete: SetNull)
  approvedBy                 User?                  @relation("CaseApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  currentRevision            CaseRevision?          @relation("CaseCurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  attempts                   Attempt[]
  sessions                   GameSession[]
  dailyCases                 DailyCase[]
  hints                      HintContent[]
  explanations               ExplanationContent[]
  validationRuns             CaseValidationRun[]
  reviews                    CaseReview[]
  revisions                  CaseRevision[]         @relation("CaseRevisions")

  @@index([diagnosisId])
  @@index([diagnosisRegistryId])
  @@index([diagnosisMappingStatus])
}

model CaseRevision {
  id                         String                 @id @default(uuid())
  caseId                     String
  revisionNumber             Int                    @default(1)
  source                     CaseSource?
  publishTrack               PublishTrack?
  title                      String
  date                       DateTime
  difficulty                 String
  history                    String
  symptoms                   String[]
  labs                       Json?
  clues                      Json?
  explanation                Json?
  differentials              String[]               @default([])
  diagnosisId                String
  diagnosisRegistryId        String?
  proposedDiagnosisText      String
  diagnosisMappingStatus     DiagnosisMappingStatus
  diagnosisMappingMethod     DiagnosisMappingMethod
  diagnosisMappingConfidence Float?
  diagnosisEditorialNote     String?
  createdByUserId            String?
  createdAt                  DateTime               @default(now())
  case                       Case                   @relation("CaseRevisions", fields: [caseId], references: [id], onDelete: Cascade)
  diagnosis                  Diagnosis              @relation(fields: [diagnosisId], references: [id], onDelete: Restrict)
  diagnosisRegistry          DiagnosisRegistry?     @relation("CaseRevisionDiagnosisRegistry", fields: [diagnosisRegistryId], references: [id], onDelete: SetNull)
  createdBy                  User?                  @relation("CaseRevisionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  currentForCase             Case?                  @relation("CaseCurrentRevision")
  validationRuns             CaseValidationRun[]
  reviews                    CaseReview[]

  @@unique([caseId, revisionNumber])
  @@index([caseId])
  @@index([diagnosisId])
  @@index([diagnosisRegistryId])
  @@index([diagnosisMappingStatus])
  @@index([createdByUserId])
  @@index([createdAt])
}

model CaseValidationRun {
  id                String             @id @default(uuid())
  caseId            String
  revisionId        String?
  source            CaseSource?
  publishTrack      PublishTrack?
  outcome           ValidationOutcome?
  validatorVersion  String?
  summary           Json?
  findings          Json?
  triggeredByUserId String?
  startedAt         DateTime           @default(now())
  completedAt       DateTime?
  case              Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  revision          CaseRevision?      @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  triggeredBy       User?              @relation("CaseValidationRunTriggeredByUser", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([revisionId])
  @@index([triggeredByUserId])
  @@index([startedAt])
}

model CaseReview {
  id             String          @id @default(uuid())
  caseId         String
  revisionId     String?
  reviewerUserId String?
  decision       ReviewDecision?
  notes          String?
  source         CaseSource?
  publishTrack   PublishTrack?
  createdAt      DateTime        @default(now())
  decidedAt      DateTime?
  case           Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  revision       CaseRevision?   @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  reviewer       User?           @relation("CaseReviewReviewerUser", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([revisionId])
  @@index([reviewerUserId])
  @@index([createdAt])
}

model HintContent {
  id        String   @id @default(uuid())
  caseId    String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model ExplanationContent {
  id        String   @id @default(uuid())
  caseId    String   @unique
  content   String
  version   String   @default("ai:v1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model GameSession {
  id          String    @id @default(uuid())
  caseId                 String
  userId                 String
  dailyCaseId            String
  userTierAtStart        String?
  currentClueIndexLegacy Int?      @default(0)
  xpAwardedAt            DateTime?
  processingAt           DateTime?
  processedAt            DateTime?
  startedAt              DateTime   @default(now())
  completedAt            DateTime?
  status                 String
  case                   Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyCase              DailyCase  @relation(fields: [dailyCaseId], references: [id], onDelete: Cascade)
  attempts               Attempt[]

  @@index([caseId])
  @@index([dailyCaseId])
  @@index([userId])
  @@index([status])
  @@index([processingAt])
  @@index([processedAt])
  @@index([processedAt, processingAt])
  @@index([startedAt])
  @@index([userId, status, completedAt])
  @@unique([userId, dailyCaseId])
}

model Attempt {
  id               String   @id @default(uuid())
  caseId           String
  userId           String?
  sessionId        String
  guess            String
  normalizedGuess  String
  selectedDiagnosisId String?
  selectedAliasId  String?
  strictMatchedDiagnosisId String?
  strictMatchedAliasId String?
  strictMatchOutcome String?
  score            Float
  result           String
  signals          Json
  evaluatorVersion String
  clueIndexAtAttempt Int?
  createdAt        DateTime @default(now())
  session          GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  selectedDiagnosis DiagnosisRegistry? @relation("AttemptSelectedDiagnosisRegistry", fields: [selectedDiagnosisId], references: [id], onDelete: SetNull)
  selectedAlias    DiagnosisAlias? @relation("AttemptSelectedAlias", fields: [selectedAliasId], references: [id], onDelete: SetNull)
  strictMatchedDiagnosis DiagnosisRegistry? @relation("AttemptStrictMatchedDiagnosisRegistry", fields: [strictMatchedDiagnosisId], references: [id], onDelete: SetNull)
  strictMatchedAlias DiagnosisAlias? @relation("AttemptStrictMatchedAlias", fields: [strictMatchedAliasId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([caseId])
  @@index([userId])
  @@index([selectedDiagnosisId])
  @@index([selectedAliasId])
  @@index([strictMatchedDiagnosisId])
  @@index([strictMatchedAliasId])
  @@index([createdAt])
  @@index([sessionId, normalizedGuess, createdAt])
  @@index([result, guess])
}

model User {
  id                        String                  @id
  clerkId                   String?                 @unique
  email                     String?
  displayName               String?
  trainingLevel             String?
  country                   String?
  individualMode            Boolean                 @default(true)
  role                      String                  @default("user")
  subscriptionTier          String                  @default("free")
  lastPlayedAt              DateTime?
  sessions                  GameSession[]
  attempts                  Attempt[]
  stats                     UserStats?
  progress                  UserProgress?
  leaderboard               LeaderboardEntry[]
  approvedCases             Case[]                  @relation("CaseApprovedByUser")
  createdCaseRevisions      CaseRevision[]          @relation("CaseRevisionCreatedByUser")
  triggeredCaseValidations  CaseValidationRun[]     @relation("CaseValidationRunTriggeredByUser")
  caseReviews               CaseReview[]            @relation("CaseReviewReviewerUser")
  organizations             UserOrganization[]

  @@index([role])
  @@index([subscriptionTier])
}

model Organization {
  id             String             @id @default(uuid())
  name           String
  type           OrganizationType
  slug           String?            @unique
  seatPriceCents Int?
  currency       String?            @default("USD")
  seatLimit      Int?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  members        UserOrganization[]

  @@index([type])
  @@index([name])
}

model UserOrganization {
  id             String                   @id @default(uuid())
  userId         String
  organizationId String
  role           OrganizationRole         @default(MEMBER)
  status         OrganizationMemberStatus @default(ACTIVE)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model UserProgress {
  id             String   @id @default(uuid())
  userId         String   @unique
  xpTotal        Int      @default(0)
  level          Int      @default(1)
  xpCurrentLevel Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([xpTotal])
}

model UserStats {
  userId        String   @id
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  lastPlayedDate DateTime? @db.Date
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyCase {
  id        String   @id @default(uuid())
  caseId    String
  date      DateTime @db.Date
  track     PublishTrack
  sequenceIndex Int
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sessions  GameSession[]
  leaderboardEntries LeaderboardEntry[]

  @@unique([date, track, sequenceIndex])
  @@index([caseId])
  @@index([date, track])
}

model LeaderboardEntry {
  id              String   @id @default(uuid())
  userId          String
  dailyCaseId     String
  score           Int
  attemptsCount   Int
  timeToComplete  Int?
  completedAt     DateTime
  rankLegacy      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyCase       DailyCase @relation(fields: [dailyCaseId], references: [id], onDelete: Cascade)

  @@unique([dailyCaseId, userId])
  @@index([dailyCaseId, score(sort: Desc), attemptsCount(sort: Asc), completedAt(sort: Asc)])
  @@index([userId, completedAt(sort: Desc)])
}
