// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum CaseEditorialStatus {
  DRAFT
  VALIDATING
  VALIDATED
  REVIEW
  NEEDS_EDIT
  APPROVED
  READY_TO_PUBLISH
  PUBLISHED
  REJECTED
}

enum ValidationOutcome {
  PASSED
  FAILED
  ERROR
}

enum ReviewDecision {
  APPROVED
  REJECTED
  NEEDS_EDIT
}

enum CaseSource {
  GENERATED
  MANUAL
  ADMIN_EDIT
  RESTORED
}

enum PublishTrack {
  DAILY
  PREMIUM
  PRACTICE
}

enum OrganizationType {
  UNIVERSITY
  HOSPITAL
  COLLEGE
  OTHER
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganizationMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum UserOnboardingStatus {
  PROFILE_REQUIRED
  ORGANIZATION_REQUIRED
  COMPLETE
}

enum DiagnosisAliasKind {
  CANONICAL
  ACCEPTED
  ABBREVIATION
  SEARCH_ONLY
}

enum DiagnosisRegistryStatus {
  ACTIVE
  HIDDEN
  DEPRECATED
  DRAFT
}

enum DiagnosisEditorialOnboardingStatus {
  NEW
  RULES_STARTED
  BRIEF_STARTED
  EDUCATION_STARTED
  CASE_STARTED
  READY_FOR_REVIEW
  COMPLETE
}

enum DiagnosisDifficultyBand {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum DiagnosisRarityBand {
  COMMON
  UNCOMMON
  RARE
}

enum DiagnosisClinicalSetting {
  OUTPATIENT
  EMERGENCY
  INPATIENT
  ICU
  COMMUNITY
}

enum DiagnosisAgeGroup {
  PEDIATRIC
  ADULT
  GERIATRIC
  ANY
}

enum DiagnosisUrgencyLevel {
  ROUTINE
  URGENT
  EMERGENT
}

enum DiagnosisMappingStatus {
  MATCHED
  REVIEW_REQUIRED
  UNRESOLVED
  NEW_REGISTRY_ENTRY_NEEDED
}

enum DiagnosisMappingMethod {
  EXACT_ALIAS
  NORMALIZED_ALIAS
  EDITOR_SELECTED
  MANUAL_CREATED
  LEGACY_BACKFILL
  NONE
}

enum DifferentialResolutionStatus {
  RESOLVED
  AMBIGUOUS
  UNRESOLVED
  REJECTED
}

enum DifferentialLinkRole {
  PRIMARY_MIMIC
  DIFFERENTIAL
  IMPORTANT_EXCLUSION
  TEACHING_DIFFERENTIAL
}

enum DiagnosisRegistryCandidateStatus {
  CANDIDATE
  NEEDS_REVIEW
  REJECTED
  MERGED
  APPROVED_PENDING_CREATE
  CREATED
}

enum DiagnosisEducationStatus {
  DRAFT
  GENERATED
  NEEDS_REVIEW
  NEEDS_EDIT
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum DiagnosisEducationSource {
  MANUAL
  AI_ASSISTED
  IMPORTED
  HYBRID
}

enum DiagnosisGraphCandidateType {
  FINDING
  INVESTIGATION
  MIMIC
  PITFALL
  MANAGEMENT
  COMPLICATION
  RECALL_PROMPT
  CASE_REASONING
}

enum DiagnosisGraphSourceType {
  CASE
  DIAGNOSIS_EDUCATION
}

enum DiagnosisGraphCandidateStatus {
  CANDIDATE
  APPROVED
  REJECTED
  MERGED
}

enum DiagnosisGraphFactStatus {
  ACTIVE
  ARCHIVED
}

model Diagnosis {
  id            String               @id @default(uuid())
  name          String               @unique
  system        String?
  embeddings    DiagnosisEmbedding[]
  synonyms      Synonym[]
  cases         Case[]
  caseRevisions CaseRevision[]
  registryEntry DiagnosisRegistry?   @relation("LegacyDiagnosisRegistry")
}

model DiagnosisEmbedding {
  id          String                      @id @default(uuid())
  diagnosisId String
  vector      Unsupported("vector(1536)")
  type        String
  createdAt   DateTime                    @default(now())
  diagnosis   Diagnosis                   @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([diagnosisId])
  @@index([type])
}

model Synonym {
  id          String    @id @default(uuid())
  term        String    @unique
  diagnosisId String
  diagnosis   Diagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([diagnosisId])
}

model DiagnosisRegistry {
  id                                    String                         @id @default(uuid())
  legacyDiagnosisId                     String?                        @unique
  canonicalName                         String
  canonicalNormalized                   String                         @unique
  displayLabel                          String
  status                                DiagnosisRegistryStatus        @default(ACTIVE)
  active                                Boolean                        @default(true)
  onboardingStatus                      DiagnosisEditorialOnboardingStatus?
  onboardingStartedAt                   DateTime?
  onboardingCompletedAt                 DateTime?
  activationReviewedByUserId            String?
  activationReviewedAt                  DateTime?
  isDescriptive                         Boolean                        @default(false)
  isCompositional                       Boolean                        @default(false)
  searchPriority                        Int                            @default(0)
  icd10Code                             String?
  icd11Code                             String?
  /// Educational or disease grouping.
  /// Examples: Neurodegenerative, Vascular, Infectious, Autoimmune, Metabolic, Neoplastic.
  category                              String?
  /// Broad clinical discipline responsible for the diagnosis.
  /// Examples: Cardiology, Neurology, Endocrinology, Infectious Disease.
  specialty                             String?
  /// More specific branch inside the specialty.
  /// Examples: Neuromuscular, Movement Disorders, Heart Failure, Electrophysiology.
  subspecialty                          String?
  /// Broad physiological/body system.
  /// Examples: Cardiovascular, Nervous System, Respiratory, Gastrointestinal.
  bodySystem                            String?
  /// More granular organ/anatomic region if useful.
  /// Examples: Brain, Spinal Cord, Peripheral Nerve, Myocardium, Liver, Kidney.
  organSystem                           String?
  /// Approximate educational difficulty for gameplay and curriculum sequencing.
  /// Examples: BASIC, INTERMEDIATE, ADVANCED.
  difficultyBand                        DiagnosisDifficultyBand?
  /// Approximate prevalence/rarity for balancing common and rare diseases.
  /// Examples: COMMON, UNCOMMON, RARE.
  rarityBand                            DiagnosisRarityBand?
  /// Typical clinical setting where the diagnosis is commonly encountered.
  /// Examples: OUTPATIENT, EMERGENCY, INPATIENT, ICU, COMMUNITY.
  clinicalSetting                       DiagnosisClinicalSetting?
  /// Typical age group where the diagnosis is most relevant.
  /// Examples: PEDIATRIC, ADULT, GERIATRIC, ANY.
  ageGroup                              DiagnosisAgeGroup?
  /// Typical urgency level for case framing.
  /// Examples: ROUTINE, URGENT, EMERGENT.
  urgencyLevel                          DiagnosisUrgencyLevel?
  /// Whether this diagnosis can appear as a playable answer.
  /// Some registry rows may exist only for aliases, mappings, or future use.
  isPlayable                            Boolean                        @default(true)
  /// Whether the generator is allowed to create new cases for this diagnosis.
  /// Some diagnoses may be playable manually but not suitable for automated generation.
  isGeneratable                         Boolean                        @default(true)
  /// Optional clue-type guidance for generation.
  /// Example: ["history", "exam", "labs", "imaging"].
  preferredClueTypes                    Json?
  /// Optional clue types to avoid or de-emphasize for this diagnosis.
  /// Example: ["imaging"] for diagnoses where imaging is not central.
  excludedClueTypes                     Json?
  notes                                 String?
  createdAt                             DateTime                       @default(now())
  updatedAt                             DateTime                       @updatedAt
  legacyDiagnosis                       Diagnosis?                     @relation("LegacyDiagnosisRegistry", fields: [legacyDiagnosisId], references: [id], onDelete: SetNull)
  activationReviewedByUser              User?                          @relation("DiagnosisRegistryActivationReviewedByUser", fields: [activationReviewedByUserId], references: [id], onDelete: SetNull)
  aliases                               DiagnosisAlias[]
  cases                                 Case[]                         @relation("CaseDiagnosisRegistry")
  caseRevisions                         CaseRevision[]                 @relation("CaseRevisionDiagnosisRegistry")
  education                             DiagnosisEducation?
  graphCandidates                       DiagnosisGraphCandidate[]      @relation("DiagnosisGraphCandidateDiagnosis")
  targetedGraphCandidates               DiagnosisGraphCandidate[]      @relation("DiagnosisGraphCandidateTargetDiagnosis")
  graphFacts                            DiagnosisGraphFact[]           @relation("DiagnosisGraphFactDiagnosis")
  targetedGraphFacts                    DiagnosisGraphFact[]           @relation("DiagnosisGraphFactTargetDiagnosis")
  resolvedCaseDifferentialMappings      CaseDifferentialMapping[]      @relation("CaseDifferentialMappingResolvedDiagnosis")
  educationDifferentialMappings         EducationDifferentialMapping[] @relation("EducationDifferentialMappingDiagnosis")
  resolvedEducationDifferentialMappings EducationDifferentialMapping[] @relation("EducationDifferentialMappingResolvedDiagnosis")
  contextualRegistryCandidates          DiagnosisRegistryCandidate[]   @relation("DiagnosisRegistryCandidateContextDiagnosis")
  createdRegistryCandidates             DiagnosisRegistryCandidate[]   @relation("DiagnosisRegistryCandidateCreatedDiagnosis")
  caseDifferentialLinks                 CaseDifferentialLink[]
  educationDifferentialLinks            EducationDifferentialLink[]
  teachingRules                         DiagnosisTeachingRule[]
  editorialBrief                        DiagnosisEditorialBrief?
  selectedAttempts                      Attempt[]                      @relation("AttemptSelectedDiagnosisRegistry")
  strictMatchedAttempts                 Attempt[]                      @relation("AttemptStrictMatchedDiagnosisRegistry")

  @@index([status])
  @@index([onboardingStatus])
  @@index([activationReviewedByUserId])
  @@index([active])
  @@index([displayLabel])
  @@index([searchPriority])
  @@index([specialty])
  @@index([bodySystem])
  @@index([category])
  @@index([difficultyBand])
  @@index([rarityBand])
  @@index([clinicalSetting])
}

model DiagnosisTeachingRule {
  id                       String            @id @default(uuid())
  diagnosisRegistryId      String
  stableKey                String
  title                    String
  category                 String
  importance               String
  rationale                String?
  acceptableManifestations Json?
  requiredDifferentials    Json?
  expectedEvidence         Json?
  difficultyHints          Json?
  avoidTooEarly            Boolean           @default(false)
  appliesToEducation       Boolean           @default(true)
  appliesToCaseGeneration  Boolean           @default(true)
  appliesToGraph           Boolean           @default(false)
  status                   String
  source                   String
  version                  Int               @default(1)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  diagnosisRegistry        DiagnosisRegistry @relation(fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)

  @@unique([diagnosisRegistryId, stableKey])
  @@index([diagnosisRegistryId])
  @@index([status])
  @@index([category])
}

model DiagnosisEditorialBrief {
  id                      String            @id @default(uuid())
  diagnosisRegistryId     String            @unique
  summary                 String
  learningGoals           Json
  requiredTeachingRuleIds Json
  requiredMimicIds        Json?
  requiredPitfalls        Json?
  keyInvestigations       Json?
  managementAnchors       Json?
  difficultyGuidance      Json?
  caseGenerationGuidance  Json?
  educationGuidance       Json?
  graphGuidance           Json?
  status                  String
  version                 Int               @default(1)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  diagnosisRegistry       DiagnosisRegistry @relation(fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([diagnosisRegistryId])
}

model DiagnosisEducation {
  id                   String                         @id @default(uuid())
  diagnosisRegistryId  String                         @unique
  title                String
  summary              Json
  clinicalPattern      Json?
  keySymptoms          Json?
  keySigns             Json?
  examPearls           Json?
  scoringSystems       Json?
  investigations       Json?
  differentials        Json?
  management           Json?
  complications        Json?
  pitfalls             Json?
  recallPrompts        Json?
  references           Json?
  editorialStatus      DiagnosisEducationStatus       @default(DRAFT)
  source               DiagnosisEducationSource       @default(MANUAL)
  version              Int                            @default(1)
  generatedAt          DateTime?
  reviewedAt           DateTime?
  reviewedByUserId     String?
  publishedAt          DateTime?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  diagnosisRegistry    DiagnosisRegistry              @relation(fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)
  reviewedBy           User?                          @relation("DiagnosisEducationReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  revisions            DiagnosisEducationRevision[]
  differentialMappings EducationDifferentialMapping[]
  differentialLinks    EducationDifferentialLink[]

  @@index([editorialStatus])
  @@index([source])
  @@index([updatedAt])
  @@index([reviewedByUserId])
}

model DiagnosisEducationRevision {
  id                   String                         @id @default(uuid())
  educationId          String
  version              Int
  snapshot             Json
  editorialStatus      DiagnosisEducationStatus
  source               DiagnosisEducationSource
  createdByUserId      String?
  createdAt            DateTime                       @default(now())
  education            DiagnosisEducation             @relation(fields: [educationId], references: [id], onDelete: Cascade)
  createdBy            User?                          @relation("DiagnosisEducationRevisionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  differentialMappings EducationDifferentialMapping[]
  differentialLinks    EducationDifferentialLink[]

  @@unique([educationId, version])
  @@index([educationId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model DiagnosisGraphCandidate {
  id                        String                        @id @default(uuid())
  diagnosisRegistryId       String
  type                      DiagnosisGraphCandidateType
  status                    DiagnosisGraphCandidateStatus @default(CANDIDATE)
  sourceType                DiagnosisGraphSourceType
  sourceId                  String
  sourceVersion             Int?
  sourcePath                String
  rawText                   String
  normalizedText            String
  dedupeKey                 String                        @unique
  payload                   Json?
  targetDiagnosisRegistryId String?
  unresolvedTargetText      String?
  confidence                Float?
  reviewedByUserId          String?
  reviewedAt                DateTime?
  reviewNote                String?
  mergedIntoId              String?
  promotedFactId            String?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  diagnosisRegistry         DiagnosisRegistry             @relation("DiagnosisGraphCandidateDiagnosis", fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)
  targetDiagnosisRegistry   DiagnosisRegistry?            @relation("DiagnosisGraphCandidateTargetDiagnosis", fields: [targetDiagnosisRegistryId], references: [id], onDelete: SetNull)
  reviewedBy                User?                         @relation("DiagnosisGraphCandidateReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  mergedInto                DiagnosisGraphCandidate?      @relation("DiagnosisGraphCandidateMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedCandidates          DiagnosisGraphCandidate[]     @relation("DiagnosisGraphCandidateMerge")
  promotedFact              DiagnosisGraphFact?           @relation("DiagnosisGraphCandidatePromotedFact", fields: [promotedFactId], references: [id], onDelete: SetNull)
  sourceFact                DiagnosisGraphFact?           @relation("DiagnosisGraphFactSourceCandidate")

  @@unique([diagnosisRegistryId, type, sourceType, sourceId, sourcePath, normalizedText])
  @@index([dedupeKey])
  @@index([diagnosisRegistryId])
  @@index([type])
  @@index([status])
  @@index([sourceType, sourceId])
  @@index([normalizedText])
  @@index([targetDiagnosisRegistryId])
  @@index([reviewedByUserId])
}

model DiagnosisGraphFact {
  id                        String                      @id @default(uuid())
  diagnosisRegistryId       String
  type                      DiagnosisGraphCandidateType
  label                     String
  normalizedLabel           String
  dedupeKey                 String                      @unique
  payload                   Json?
  targetDiagnosisRegistryId String?
  status                    DiagnosisGraphFactStatus    @default(ACTIVE)
  sourceCandidateId         String?                     @unique
  provenance                Json?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  diagnosisRegistry         DiagnosisRegistry           @relation("DiagnosisGraphFactDiagnosis", fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)
  targetDiagnosisRegistry   DiagnosisRegistry?          @relation("DiagnosisGraphFactTargetDiagnosis", fields: [targetDiagnosisRegistryId], references: [id], onDelete: SetNull)
  sourceCandidate           DiagnosisGraphCandidate?    @relation("DiagnosisGraphFactSourceCandidate", fields: [sourceCandidateId], references: [id], onDelete: SetNull)
  promotedCandidates        DiagnosisGraphCandidate[]   @relation("DiagnosisGraphCandidatePromotedFact")

  @@unique([diagnosisRegistryId, type, normalizedLabel, targetDiagnosisRegistryId])
  @@index([dedupeKey])
  @@index([diagnosisRegistryId])
  @@index([type])
  @@index([status])
  @@index([normalizedLabel])
  @@index([targetDiagnosisRegistryId])
}

model DiagnosisAlias {
  id                    String             @id @default(uuid())
  diagnosisRegistryId   String
  term                  String
  normalizedTerm        String
  kind                  DiagnosisAliasKind
  acceptedForMatch      Boolean            @default(false)
  rank                  Int                @default(0)
  source                String?
  active                Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  diagnosis             DiagnosisRegistry  @relation(fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)
  selectedAttempts      Attempt[]          @relation("AttemptSelectedAlias")
  strictMatchedAttempts Attempt[]          @relation("AttemptStrictMatchedAlias")

  @@unique([diagnosisRegistryId, normalizedTerm])
  @@index([normalizedTerm, active])
  @@index([diagnosisRegistryId, active, acceptedForMatch])
}

model Case {
  id                         String                    @id @default(uuid())
  publicNumber               Int?                      @unique
  title                      String
  date                       DateTime                  @unique
  difficulty                 String
  history                    String
  symptoms                   String[]
  labs                       Json?
  clues                      Json?
  explanation                Json?
  differentials              String[]                  @default([])
  editorialStatus            CaseEditorialStatus?
  approvedAt                 DateTime?
  publishedAt                DateTime?
  approvedByUserId           String?
  currentRevisionId          String?                   @unique
  diagnosisId                String?
  diagnosisRegistryId        String?
  proposedDiagnosisText      String
  diagnosisMappingStatus     DiagnosisMappingStatus
  diagnosisMappingMethod     DiagnosisMappingMethod
  diagnosisMappingConfidence Float?
  diagnosisEditorialNote     String?
  diagnosis                  Diagnosis?                @relation(fields: [diagnosisId], references: [id], onDelete: Restrict)
  diagnosisRegistry          DiagnosisRegistry?        @relation("CaseDiagnosisRegistry", fields: [diagnosisRegistryId], references: [id], onDelete: SetNull)
  approvedBy                 User?                     @relation("CaseApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  currentRevision            CaseRevision?             @relation("CaseCurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  attempts                   Attempt[]
  sessions                   GameSession[]
  dailyCases                 DailyCase[]
  hints                      HintContent[]
  explanations               ExplanationContent[]
  validationRuns             CaseValidationRun[]
  reviews                    CaseReview[]
  revisions                  CaseRevision[]            @relation("CaseRevisions")
  differentialMappings       CaseDifferentialMapping[]
  differentialLinks          CaseDifferentialLink[]

  @@index([diagnosisId])
  @@index([diagnosisRegistryId])
  @@index([diagnosisMappingStatus])
}

model CaseRevision {
  id                         String                    @id @default(uuid())
  caseId                     String
  revisionNumber             Int                       @default(1)
  source                     CaseSource?
  publishTrack               PublishTrack?
  title                      String
  date                       DateTime
  difficulty                 String
  history                    String
  symptoms                   String[]
  labs                       Json?
  clues                      Json?
  explanation                Json?
  differentials              String[]                  @default([])
  diagnosisId                String?
  diagnosisRegistryId        String?
  proposedDiagnosisText      String
  diagnosisMappingStatus     DiagnosisMappingStatus
  diagnosisMappingMethod     DiagnosisMappingMethod
  diagnosisMappingConfidence Float?
  diagnosisEditorialNote     String?
  createdByUserId            String?
  createdAt                  DateTime                  @default(now())
  case                       Case                      @relation("CaseRevisions", fields: [caseId], references: [id], onDelete: Cascade)
  diagnosis                  Diagnosis?                @relation(fields: [diagnosisId], references: [id], onDelete: Restrict)
  diagnosisRegistry          DiagnosisRegistry?        @relation("CaseRevisionDiagnosisRegistry", fields: [diagnosisRegistryId], references: [id], onDelete: SetNull)
  createdBy                  User?                     @relation("CaseRevisionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  currentForCase             Case?                     @relation("CaseCurrentRevision")
  validationRuns             CaseValidationRun[]
  reviews                    CaseReview[]
  differentialMappings       CaseDifferentialMapping[]
  differentialLinks          CaseDifferentialLink[]

  @@unique([caseId, revisionNumber])
  @@index([caseId])
  @@index([diagnosisId])
  @@index([diagnosisRegistryId])
  @@index([diagnosisMappingStatus])
  @@index([createdByUserId])
  @@index([createdAt])
}

model CaseDifferentialMapping {
  id                          String                       @id @default(uuid())
  caseId                      String
  revisionId                  String?
  rawText                     String
  normalizedText              String
  resolvedDiagnosisRegistryId String?
  status                      DifferentialResolutionStatus
  matchType                   String?
  confidence                  Float?
  suggestions                 Json?
  sourcePath                  String?
  dedupeKey                   String                       @unique
  reviewedByUserId            String?
  reviewedAt                  DateTime?
  reviewNote                  String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  case                        Case                         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  revision                    CaseRevision?                @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  resolvedDiagnosisRegistry   DiagnosisRegistry?           @relation("CaseDifferentialMappingResolvedDiagnosis", fields: [resolvedDiagnosisRegistryId], references: [id], onDelete: SetNull)
  reviewedBy                  User?                        @relation("CaseDifferentialMappingReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  differentialLinks           CaseDifferentialLink[]

  @@unique([caseId, revisionId, sourcePath, normalizedText])
  @@index([caseId])
  @@index([revisionId])
  @@index([normalizedText])
  @@index([resolvedDiagnosisRegistryId])
  @@index([status])
}

model EducationDifferentialMapping {
  id                          String                       @id @default(uuid())
  educationId                 String
  revisionId                  String?
  diagnosisRegistryId         String
  rawText                     String
  normalizedText              String
  resolvedDiagnosisRegistryId String?
  status                      DifferentialResolutionStatus
  matchType                   String?
  confidence                  Float?
  suggestions                 Json?
  sourcePath                  String?
  dedupeKey                   String                       @unique
  reviewedByUserId            String?
  reviewedAt                  DateTime?
  reviewNote                  String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  education                   DiagnosisEducation           @relation(fields: [educationId], references: [id], onDelete: Cascade)
  revision                    DiagnosisEducationRevision?  @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  diagnosisRegistry           DiagnosisRegistry            @relation("EducationDifferentialMappingDiagnosis", fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)
  resolvedDiagnosisRegistry   DiagnosisRegistry?           @relation("EducationDifferentialMappingResolvedDiagnosis", fields: [resolvedDiagnosisRegistryId], references: [id], onDelete: SetNull)
  reviewedBy                  User?                        @relation("EducationDifferentialMappingReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  differentialLinks           EducationDifferentialLink[]

  @@unique([educationId, revisionId, sourcePath, normalizedText])
  @@index([educationId])
  @@index([revisionId])
  @@index([diagnosisRegistryId])
  @@index([normalizedText])
  @@index([resolvedDiagnosisRegistryId])
  @@index([status])
}

model DiagnosisRegistryCandidate {
  id                          String                           @id @default(uuid())
  proposedCanonicalName       String
  proposedCanonicalNormalized String
  proposedDisplayLabel        String
  proposedAliases             Json?
  sourceType                  String
  sourceId                    String
  sourceMappingId             String?
  sourceRawText               String
  contextDiagnosisRegistryId  String?
  duplicateSuggestions        Json?
  status                      DiagnosisRegistryCandidateStatus @default(CANDIDATE)
  reviewerUserId              String?
  reviewedAt                  DateTime?
  reviewNote                  String?
  createdRegistryId           String?
  approvedByUserId            String?
  approvedAt                  DateTime?
  mergeTargetCandidateId      String?
  creationSnapshot            Json?
  createdAt                   DateTime                         @default(now())
  updatedAt                   DateTime                         @updatedAt
  contextDiagnosisRegistry    DiagnosisRegistry?               @relation("DiagnosisRegistryCandidateContextDiagnosis", fields: [contextDiagnosisRegistryId], references: [id], onDelete: SetNull)
  reviewerUser                User?                            @relation("DiagnosisRegistryCandidateReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  createdRegistry             DiagnosisRegistry?               @relation("DiagnosisRegistryCandidateCreatedDiagnosis", fields: [createdRegistryId], references: [id], onDelete: SetNull)
  approvedByUser              User?                            @relation("DiagnosisRegistryCandidateApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  mergeTargetCandidate        DiagnosisRegistryCandidate?      @relation("DiagnosisRegistryCandidateMergeTarget", fields: [mergeTargetCandidateId], references: [id], onDelete: SetNull)
  mergedRegistryCandidates    DiagnosisRegistryCandidate[]     @relation("DiagnosisRegistryCandidateMergeTarget")

  @@unique([sourceMappingId, proposedCanonicalNormalized])
  @@index([proposedCanonicalNormalized])
  @@index([sourceType, sourceId])
  @@index([sourceMappingId])
  @@index([contextDiagnosisRegistryId])
  @@index([status])
  @@index([reviewerUserId])
  @@index([createdRegistryId])
  @@index([approvedByUserId])
  @@index([mergeTargetCandidateId])
  @@index([createdAt])
}

model DiagnosisRegistryMergeLog {
  id                        String   @id @default(uuid())
  sourceDiagnosisRegistryId String
  targetDiagnosisRegistryId String
  reason                    String?
  analysisSnapshot          Json
  reassignmentSummary       Json
  performedByUserId         String?
  performedAt               DateTime @default(now())
  createdAt                 DateTime @default(now())

  @@index([sourceDiagnosisRegistryId])
  @@index([targetDiagnosisRegistryId])
  @@index([performedByUserId])
  @@index([performedAt])
}

model CaseDifferentialLink {
  id                  String                   @id @default(uuid())
  caseId              String
  caseRevisionId      String?
  sourceMappingId     String?
  diagnosisRegistryId String
  role                DifferentialLinkRole
  confidence          Float?
  sourceText          String
  dedupeKey           String                   @unique
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  case                Case                     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseRevision        CaseRevision?            @relation(fields: [caseRevisionId], references: [id], onDelete: Cascade)
  sourceMapping       CaseDifferentialMapping? @relation(fields: [sourceMappingId], references: [id], onDelete: SetNull)
  diagnosisRegistry   DiagnosisRegistry        @relation(fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)

  @@unique([caseId, caseRevisionId, diagnosisRegistryId])
  @@index([caseId])
  @@index([caseRevisionId])
  @@index([sourceMappingId])
  @@index([diagnosisRegistryId])
  @@index([role])
}

model EducationDifferentialLink {
  id                  String                        @id @default(uuid())
  educationId         String
  educationRevisionId String?
  sourceMappingId     String?
  diagnosisRegistryId String
  role                DifferentialLinkRole
  confidence          Float?
  sourceText          String
  dedupeKey           String                        @unique
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  education           DiagnosisEducation            @relation(fields: [educationId], references: [id], onDelete: Cascade)
  educationRevision   DiagnosisEducationRevision?   @relation(fields: [educationRevisionId], references: [id], onDelete: Cascade)
  sourceMapping       EducationDifferentialMapping? @relation(fields: [sourceMappingId], references: [id], onDelete: SetNull)
  diagnosisRegistry   DiagnosisRegistry             @relation(fields: [diagnosisRegistryId], references: [id], onDelete: Cascade)

  @@unique([educationId, educationRevisionId, diagnosisRegistryId])
  @@index([educationId])
  @@index([educationRevisionId])
  @@index([sourceMappingId])
  @@index([diagnosisRegistryId])
  @@index([role])
}

model CaseValidationRun {
  id                String             @id @default(uuid())
  caseId            String
  revisionId        String?
  source            CaseSource?
  publishTrack      PublishTrack?
  outcome           ValidationOutcome?
  validatorVersion  String?
  summary           Json?
  findings          Json?
  triggeredByUserId String?
  startedAt         DateTime           @default(now())
  completedAt       DateTime?
  case              Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  revision          CaseRevision?      @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  triggeredBy       User?              @relation("CaseValidationRunTriggeredByUser", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([revisionId])
  @@index([triggeredByUserId])
  @@index([startedAt])
}

model CaseReview {
  id             String          @id @default(uuid())
  caseId         String
  revisionId     String?
  reviewerUserId String?
  decision       ReviewDecision?
  notes          String?
  source         CaseSource?
  publishTrack   PublishTrack?
  createdAt      DateTime        @default(now())
  decidedAt      DateTime?
  case           Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  revision       CaseRevision?   @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  reviewer       User?           @relation("CaseReviewReviewerUser", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([revisionId])
  @@index([reviewerUserId])
  @@index([createdAt])
}

model HintContent {
  id        String   @id @default(uuid())
  caseId    String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model ExplanationContent {
  id        String   @id @default(uuid())
  caseId    String   @unique
  content   String
  version   String   @default("ai:v1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model GameSession {
  id                     String    @id @default(uuid())
  caseId                 String
  userId                 String
  dailyCaseId            String
  userTierAtStart        String?
  currentClueIndexLegacy Int?      @default(0)
  xpAwardedAt            DateTime?
  processingAt           DateTime?
  processedAt            DateTime?
  startedAt              DateTime  @default(now())
  completedAt            DateTime?
  status                 String
  case                   Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyCase              DailyCase @relation(fields: [dailyCaseId], references: [id], onDelete: Cascade)
  attempts               Attempt[]

  @@unique([userId, dailyCaseId])
  @@index([caseId])
  @@index([dailyCaseId])
  @@index([userId])
  @@index([status])
  @@index([processingAt])
  @@index([processedAt])
  @@index([processedAt, processingAt])
  @@index([startedAt])
  @@index([userId, status, completedAt])
}

model Attempt {
  id                       String             @id @default(uuid())
  caseId                   String
  userId                   String?
  sessionId                String
  guess                    String
  normalizedGuess          String
  selectedDiagnosisId      String?
  selectedAliasId          String?
  strictMatchedDiagnosisId String?
  strictMatchedAliasId     String?
  strictMatchOutcome       String?
  score                    Float
  result                   String
  signals                  Json
  evaluatorVersion         String
  clueIndexAtAttempt       Int?
  createdAt                DateTime           @default(now())
  session                  GameSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  case                     Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user                     User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  selectedDiagnosis        DiagnosisRegistry? @relation("AttemptSelectedDiagnosisRegistry", fields: [selectedDiagnosisId], references: [id], onDelete: SetNull)
  selectedAlias            DiagnosisAlias?    @relation("AttemptSelectedAlias", fields: [selectedAliasId], references: [id], onDelete: SetNull)
  strictMatchedDiagnosis   DiagnosisRegistry? @relation("AttemptStrictMatchedDiagnosisRegistry", fields: [strictMatchedDiagnosisId], references: [id], onDelete: SetNull)
  strictMatchedAlias       DiagnosisAlias?    @relation("AttemptStrictMatchedAlias", fields: [strictMatchedAliasId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([caseId])
  @@index([userId])
  @@index([selectedDiagnosisId])
  @@index([selectedAliasId])
  @@index([strictMatchedDiagnosisId])
  @@index([strictMatchedAliasId])
  @@index([createdAt])
  @@index([sessionId, normalizedGuess, createdAt])
  @@index([result, guess])
}

model User {
  id                                    String                         @id
  clerkId                               String?                        @unique
  email                                 String?
  username                              String?
  normalizedUsername                    String?                        @unique
  trainingLevel                         String?
  country                               String?
  individualMode                        Boolean                        @default(true)
  onboardingStatus                      UserOnboardingStatus           @default(PROFILE_REQUIRED)
  onboardingCompletedAt                 DateTime?
  primaryOrganizationId                 String?
  role                                  String                         @default("user")
  subscriptionTier                      String                         @default("free")
  lastPlayedAt                          DateTime?
  createdAt                             DateTime                       @default(now())
  updatedAt                             DateTime                       @updatedAt
  sessions                              GameSession[]
  attempts                              Attempt[]
  stats                                 UserStats?
  progress                              UserProgress?
  settings                              UserSettings?
  notifications                         Notification[]
  notificationPreferences               NotificationPreference[]
  pushDeviceTokens                      PushDeviceToken[]
  leaderboard                           LeaderboardEntry[]
  approvedCases                         Case[]                         @relation("CaseApprovedByUser")
  createdCaseRevisions                  CaseRevision[]                 @relation("CaseRevisionCreatedByUser")
  triggeredCaseValidations              CaseValidationRun[]            @relation("CaseValidationRunTriggeredByUser")
  caseReviews                           CaseReview[]                   @relation("CaseReviewReviewerUser")
  reviewedDiagnosisEducation            DiagnosisEducation[]           @relation("DiagnosisEducationReviewedByUser")
  createdDiagnosisEducationRevisions    DiagnosisEducationRevision[]   @relation("DiagnosisEducationRevisionCreatedByUser")
  reviewedDiagnosisGraphCandidates      DiagnosisGraphCandidate[]      @relation("DiagnosisGraphCandidateReviewedByUser")
  reviewedCaseDifferentialMappings      CaseDifferentialMapping[]      @relation("CaseDifferentialMappingReviewedByUser")
  reviewedEducationDifferentialMappings EducationDifferentialMapping[] @relation("EducationDifferentialMappingReviewedByUser")
  reviewedDiagnosisRegistryCandidates   DiagnosisRegistryCandidate[]   @relation("DiagnosisRegistryCandidateReviewer")
  approvedDiagnosisRegistryCandidates   DiagnosisRegistryCandidate[]   @relation("DiagnosisRegistryCandidateApprovedByUser")
  activationReviewedDiagnoses           DiagnosisRegistry[]            @relation("DiagnosisRegistryActivationReviewedByUser")
  primaryOrganization                   Organization?                  @relation("UserPrimaryOrganization", fields: [primaryOrganizationId], references: [id], onDelete: SetNull)
  organizations                         UserOrganization[]

  @@index([role])
  @@index([subscriptionTier])
  @@index([onboardingStatus])
  @@index([primaryOrganizationId])
  @@index([normalizedUsername])
}

model Organization {
  id             String             @id @default(uuid())
  name           String
  type           OrganizationType
  slug           String?            @unique
  seatPriceCents Int?
  currency       String?            @default("USD")
  seatLimit      Int?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  members        UserOrganization[]
  primaryUsers   User[]             @relation("UserPrimaryOrganization")

  @@index([type])
  @@index([name])
}

model UserOrganization {
  id             String                   @id @default(uuid())
  userId         String
  organizationId String
  role           OrganizationRole         @default(MEMBER)
  status         OrganizationMemberStatus @default(ACTIVE)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model UserSettings {
  id                       String   @id @default(uuid())
  userId                   String   @unique
  showTimer                Boolean  @default(true)
  hintsEnabled             Boolean  @default(true)
  autocompleteEnabled      Boolean  @default(true)
  difficultyPreference     String   @default("STANDARD")
  spacedRepetitionEnabled  Boolean  @default(false)
  leaderboardProfilePublic Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id             String    @id @default(uuid())
  userId         String
  type           String
  category       String
  title          String
  body           String
  data           Json?
  priority       String    @default("normal")
  readAt         DateTime?
  seenAt         DateTime?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?
  idempotencyKey String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@index([type])
  @@index([category])
}

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String
  category     String
  inAppEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(false)
  emailEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}

model PushDeviceToken {
  id         String    @id @default(uuid())
  userId     String
  token      String    @unique
  platform   String
  deviceId   String?
  appVersion String?
  lastSeenAt DateTime
  disabledAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserProgress {
  id             String   @id @default(uuid())
  userId         String   @unique
  xpTotal        Int      @default(0)
  level          Int      @default(1)
  xpCurrentLevel Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([xpTotal])
}

model UserStats {
  userId         String    @id
  currentStreak  Int       @default(0)
  bestStreak     Int       @default(0)
  lastPlayedDate DateTime? @db.Date
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyCase {
  id                 String             @id @default(uuid())
  caseId             String
  date               DateTime           @db.Date
  track              PublishTrack
  sequenceIndex      Int
  createdAt          DateTime           @default(now())
  case               Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sessions           GameSession[]
  leaderboardEntries LeaderboardEntry[]

  @@unique([date, track, sequenceIndex])
  @@index([caseId])
  @@index([date, track])
}

model LeaderboardEntry {
  id             String    @id @default(uuid())
  userId         String
  dailyCaseId    String
  score          Int
  attemptsCount  Int
  timeToComplete Int?
  completedAt    DateTime
  rankLegacy     Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyCase      DailyCase @relation(fields: [dailyCaseId], references: [id], onDelete: Cascade)

  @@unique([dailyCaseId, userId])
  @@index([dailyCaseId, score(sort: Desc), attemptsCount(sort: Asc), timeToComplete(sort: Asc), completedAt(sort: Asc)])
  @@index([userId, completedAt(sort: Desc)])
}
