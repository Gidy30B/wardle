VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
VITE_CLERK_JWT_AUDIENCE=your-api

# Backend public API base URL (Railway or other host)
# Example: https://your-backend.up.railway.app/api
VITE_API_BASE_URL=

# Optional fallback key supported by the app
VITE_API_URL=

# Public app URL used in share text
# Example: https://your-app.vercel.app
VITE_SHARE_URL=

# Firebase Web Messaging public config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Enable development replay payloads on startup/refresh.
VITE_ENABLE_DEV_REPLAY=false
