VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Production Capacitor builds should use a verified HTTPS App Link origin.
VITE_NATIVE_AUTH_APP_LINK_ORIGIN=
# Optional development/custom-scheme fallback. Register this in Clerk OAuth redirect URLs.
VITE_NATIVE_AUTH_CUSTOM_CALLBACK_URL=app.wardle.medcase://sso-callback
VITE_API_URL=/api
VITE_NATIVE_API_URL=https://<railway-backend-domain>/api
VITE_WS_URL=
VITE_NATIVE_WS_URL=https://<railway-backend-domain>
VITE_CLERK_JWT_AUDIENCE=
VITE_SHARE_URL=
# React is the default gameplay renderer. Phaser is deprecated and should only
# be enabled deliberately for legacy fallback/debug checks.
# VITE_GAMEPLAY_RENDERER=phaser
